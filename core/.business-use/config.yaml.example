# Project Configuration Example
# Copy this file to config.yaml and customize for your project

# API key for Business-Use server authentication
# Generate with: business-use init
api_key: "your_api_key_here"

# Database Configuration
# Choose ONE of these configurations:

# Option 1: Local SQLite (simple, recommended for development)
database_path: "./.business-use/db.sqlite"

# Option 2: PostgreSQL/Neon (cloud database, recommended for production)
# Uncomment and configure this if using PostgreSQL:
# database_url: "postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname"
#
# Note: When database_url is set, the application uses PostgreSQL.
# When database_url is not set, it uses SQLite at database_path.

# Logging level: DEBUG, INFO, WARNING, ERROR
log_level: "info"

# Enable debug mode (verbose SQL queries, etc.)
debug: false

# Environment name (e.g., local, dev, staging, prod)
env: "local"

# --- Notification settings (optional) ---

# Slack incoming webhook URL for failure notifications
# slack_webhook_url: "https://hooks.slack.com/services/T.../B.../xxx"

# Sentry DSN for error tracking (requires: pip install business-use-core[notifications])
# sentry_dsn: "https://xxx@o123.ingest.sentry.io/456"

# Minimum seconds between notifications for the same (flow, status) pair (0 = disabled)
# notify_throttle_seconds: 60

# Environment Variable Overrides (higher priority than YAML):
# BUSINESS_USE_API_KEY
# BUSINESS_USE_DATABASE_URL
# BUSINESS_USE_DATABASE_PATH
# BUSINESS_USE_LOG_LEVEL
# BUSINESS_USE_ENV
# BUSINESS_USE_DEBUG
# BUSINESS_USE_SLACK_WEBHOOK_URL
# SENTRY_DSN
# BUSINESS_USE_NOTIFY_THROTTLE_SECONDS
